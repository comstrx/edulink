# Copy to .env and fill with your Supabase project values.
# These VITE_ vars ship in the client bundle — use only the anon/publishable key
# here, never the service_role key (that lives in Edge Function secrets).
VITE_SUPABASE_PROJECT_ID=your-project-id
VITE_SUPABASE_URL=https://your-project-id.supabase.co
VITE_SUPABASE_PUBLISHABLE_KEY=your-anon-publishable-key
